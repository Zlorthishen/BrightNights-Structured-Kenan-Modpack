msgid "Adds numerous military themed professions"
msgstr "添加大量军事主题职业"

#: .\npc\classes.json
msgid "Soldier"
msgstr "士兵"

#: .\npc\classes.json
msgid "I'm just here for the paycheck."
msgstr "我只是来领薪水的。"

