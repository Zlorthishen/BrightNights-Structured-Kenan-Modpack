#: .\tl_tea_leaf.json
msgid "green tea leaf"
msgid_plural "green tea leaves"
msgstr[0] "綠茶茶葉"

#. ~ Description for {'str': 'green tea leaf', 'str_pl': 'green tea leaves'}
#: .\tl_tea_leaf.json
msgid ""
"It is green tea leaves. You can use green tea or you can eat it raw. It is "
"necessary to eat as much as you feel unwell to heal your hunger."
msgstr "這是綠茶茶葉。你可以用來泡綠茶，也可以直接生吃。需要根據身體不適程度食用足夠量來緩解飢餓。"

#: .\tl_tea_leaf.json
msgid "oolong tea leaf"
msgid_plural "oolong tea leaves"
msgstr[0] "烏龍茶茶葉"

#. ~ Description for {'str': 'oolong tea leaf', 'str_pl': 'oolong tea leaves'}
#: .\tl_tea_leaf.json
msgid ""
"Oolong tea leaves. You can use oolong tea or you can eat it raw. It is "
"necessary to eat as much as you feel unwell to heal your hunger."
msgstr "烏龍茶茶葉。你可以用來泡烏龍茶，也可以直接生吃。需要根據身體不適程度食用足夠量來緩解飢餓。"
