msgstr "一件大號全長皮風衣。擁有多個口袋用於存儲物品。"

#: .\armor_xl.json
msgid "XL sleeveless duster"
msgid_plural "XL sleeveless dusters"
msgstr[0] "XL號無袖長款風衣"

#. ~ Description for {'str': 'XL sleeveless duster'}
