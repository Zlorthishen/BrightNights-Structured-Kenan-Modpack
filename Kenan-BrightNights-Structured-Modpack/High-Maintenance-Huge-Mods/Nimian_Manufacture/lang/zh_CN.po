#: .\nm_ammo.json
msgid "Prepared laser charge, ready to be used in compatible laser weapons."
msgstr "预制激光充能弹，可用于兼容的激光武器。"

#: .\nm_ammo.json
msgid "handmade laser charge"
msgid_plural "handmade laser charges"
msgstr[0] "手工激光充能弹"

#. ~ Description for {'str': 'handmade laser charge'}
#: .\nm_ammo.json
