#. ~ Description for {'str': 'maggi goreng', 'str_pl': 'maggi goreng'}
#: .\items\comestibles\meat_dishes.json
msgid ""
"Mie goreng, Indo-Malay fried noodles, made with Maggi brand instant noodles."
msgstr "美極炒麵，印度尼西亞-馬來西亞風味的炒麵，使用美極牌方便麵製作。"

#: .\items\comestibles\meat_dishes.json
msgid "mie goreng"
msgid_plural "mie goreng"
msgstr[0] "炒麵"

#. ~ Conditional name for {'str': 'mie goreng', 'str_pl': 'mie goreng'} when
