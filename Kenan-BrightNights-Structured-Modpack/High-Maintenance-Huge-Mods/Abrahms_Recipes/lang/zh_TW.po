msgid "maggi goreng"
msgid_plural "maggi goreng"
msgstr[0] "美極炒麵"

#. ~ Conditional name for {'str': 'maggi goreng', 'str_pl': 'maggi goreng'}
#. when FLAG matches CANNIBALISM
