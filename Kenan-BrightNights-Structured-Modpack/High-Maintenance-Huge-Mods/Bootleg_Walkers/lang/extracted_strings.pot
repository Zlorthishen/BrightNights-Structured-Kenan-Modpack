msgstr ""

#: .\walker_mon.json
msgid "flamer walker"
msgid_plural "flamer walkers"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'flamer walker'}
#: .\walker_mon.json
msgid ""
"A Northrup ATSV cobbled together from scrap.  Armed with a heavy "
"flamethrower, it is extremely deadly.  Still, you shouldn't expect the "
