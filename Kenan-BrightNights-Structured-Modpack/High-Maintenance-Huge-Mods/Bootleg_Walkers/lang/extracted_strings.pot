msgid "packed bootleg walker"
msgid_plural "packed bootleg walkers"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'packed bootleg walker'}
#: .\walker_item.json
msgid ""
"An inactive bootleg walker, packed for transport.  Armed with a pair of 5.56"
" anti-personnel rifles and a tazer.  Use this item to unpack and load with "
"up to 1000 5.56 NATO M855A1 rounds."
msgstr ""

