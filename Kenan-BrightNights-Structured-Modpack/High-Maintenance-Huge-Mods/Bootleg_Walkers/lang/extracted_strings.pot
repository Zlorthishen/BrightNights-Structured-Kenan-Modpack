msgid "packed scrap walker"
msgid_plural "packed scrap walkers"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'packed scrap walker'}
#: .\walker_item.json
msgid ""
"A severely damaged Northrup ATSV, packed for transport.  Armed with a 5.56 "
"anti-personnel rifle, an anti-vehicle 40mm grenade launcher and a tazer.  "
"Use this item to unpack and load with up to 220 5.56 NATO M855A1 and 12 40mm"
" frag rounds."
msgstr ""

#: .\walker_item.json
msgid "packed unarmed walker"
msgid_plural "packed unarmed walkers"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'packed unarmed walker'}
#: .\walker_item.json
msgid ""
"A Northrup ATSV cobbled together from scrap, packed for transport.  Armed "
"with a only a tazer, it is ineffective in combat, and really should have "
"some weapons installed before activation."
msgstr ""

#: .\walker_item.json
msgid "packed unarmed super walker"
msgid_plural "packed unarmed super walkers"
msgstr[0] ""
msgstr[1] ""

#. ~ Use action friendly_msg for {'str': 'packed unarmed super walker'}.
#. ~ Use action friendly_msg for {'str': 'packed super walker'}.
#: .\walker_item.json
