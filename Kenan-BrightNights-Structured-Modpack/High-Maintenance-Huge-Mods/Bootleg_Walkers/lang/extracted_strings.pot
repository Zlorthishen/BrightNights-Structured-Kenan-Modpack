msgid "packed super walker"
msgid_plural "packed super walkers"
msgstr[0] ""
msgstr[1] ""

#. ~ Use action hostile_msg for {'str': 'packed super walker'}.
#: .\walker_item.json
msgid "You misprogram the walker.  Oops."
msgstr ""

#. ~ Description for {'str': 'packed super walker'}
