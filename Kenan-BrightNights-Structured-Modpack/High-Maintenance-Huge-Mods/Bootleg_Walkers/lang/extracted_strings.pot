msgstr ""

#. ~ Use action hostile_msg for {'str': 'packed unarmed super walker'}.
#: .\walker_item.json
msgid "You misprogram the walker! Embrace Deus Machina's purification!"
msgstr ""

#. ~ Description for {'str': 'packed unarmed super walker'}
#: .\walker_item.json
msgid ""
"A large combat walker based on the Northrup ATSV, packed for transport.  "
"Though it is armed with electroshock and -magnet units alongside "
"mechadendrite-mounted blades, you really should install its primary weapon "
"systems before activation."
msgstr ""

