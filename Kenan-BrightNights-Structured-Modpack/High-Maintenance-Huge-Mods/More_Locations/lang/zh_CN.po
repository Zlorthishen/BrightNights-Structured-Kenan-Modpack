#: .\NPC_missions.json
msgid "More Locations Locator Hologram"
msgstr "更多地点定位器全息影像"

#: .\NPC_missions.json
msgid "Hologram Protection"
msgstr "全息影像防护"

#. ~ Description for {'str': 'Hologram Protection'}
#: .\NPC_missions.json
msgid "\"I am programmed to not engage wandering monsters.\""
msgstr "\"我的程序设定为不与游荡怪物交战。\""

#: .\NPC_missions.json
msgid "More Locations Mansion Locator Hologram"
msgstr "更多地点宅邸定位器全息影像"

#: .\NPC_missions.json
msgid "More Locations Factory Locator Hologram"
msgstr "更多地点工厂定位器全息影像"

#: .\NPC_missions.json
