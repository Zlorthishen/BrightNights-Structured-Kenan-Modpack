#: .\items_NPC_missions.json
msgid "Hologram Projector - Locator of Apartment Towers"
msgid_plural "Hologram Projector - Locator of Apartment Towerss"
msgstr[0] "全息投影仪 - 公寓塔楼定位器"

#. ~ Description for {'str': 'Hologram Projector - Locator of Apartment
#. Towers'}
#: .\items_NPC_missions.json
msgid ""
"This is a hologram projector which generates an interactive hologram when "
