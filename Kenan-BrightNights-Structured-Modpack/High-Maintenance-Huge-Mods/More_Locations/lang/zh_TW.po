msgid " <given_name>.  Died as he lived, drunk and on fire."
msgstr "<given_name>。死得其所，醉醺醺地燒死了。"

#: .\snippets.json
msgid ""
" <full_name> & <full_name>.  Crashed their motorcycles at 120mph.  Buried "
"the pieces together."
msgstr "<full_name>與<full_name>。以120英里時速撞毀摩托車。殘骸合葬一處。"

#: .\snippets.json
