msgstr "掠奪者"

#: .\snippets.json
msgid "Real work for real people!"
msgstr "真正的工作給真正的人！"

#: .\snippets.json
msgid "Strike!"
msgstr "罷工！"

#: .\snippets.json
msgid "Robots stole my job!"
msgstr "機器人搶走了我的工作！"

#: .\snippets.json
msgid "robot labor=slave labor"
msgstr "機器人勞動=奴隸勞動"

#: .\snippets.json
msgid "Bring back our jobs!"
msgstr "還我們的工作！"

#: .\snippets.json
msgid "Robots go home!"
msgstr "機器人滾回家！"

#: .\snippets.json
msgid "Human labor"
msgstr "人類勞動"

#: .\snippets.json
msgid "We want our old factory!"
msgstr "我們要奪回我們的老工廠！"

#: .\snippets.json
msgid "Smash the Bots!"
msgstr "砸爛那些機器人！"

#: .\snippets.json
msgid "Here Lies  <full_name>.  What a Jerk."
msgstr "此處長眠著<full_name>。真是個混蛋。"

#: .\snippets.json
msgid " <full_name>.  Eaten by wolves."
msgstr "<full_name>。被狼群吞噬。"

#: .\snippets.json
msgid " <full_name>.  Infected."
msgstr "<full_name>。感染身亡。"

#: .\snippets.json
msgid "We send <full_name> on to Valhalla"
