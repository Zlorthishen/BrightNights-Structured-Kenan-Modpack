msgstr "<full_name>。喝下神秘血清，突變致死。"

#: .\snippets.json
msgid " <given_name>.  We'll never see another like him."
msgstr "<given_name>。我們再也見不到像他這樣的人了。"

#: .\snippets.json
msgid " <full_name>.  Done in by mutant wasps."
msgstr "<full_name>。被變異黃蜂幹掉。"

