#: .\at_ammo.json
msgid "6x36mm"
msgid_plural "6x36mms"
msgstr[0] "6x36毫米"

#. ~ Description for {'str': '6x36mm'}
#: .\at_ammo.json
msgid ""
"A small prototype round for the military's 'low-power, high-capacity' "
"applications, this particular round was designed for testing in weapons "
"primarily used while mounted."
msgstr "一种为军方'低威力、高容量'应用设计的小型原型弹药，这种特殊弹药主要用于测试安装在载具上的武器。"

#: .\at_ammo.json .\at_ammo_types.json
msgid "11mm"
msgid_plural "11mms"
msgstr[0] "11毫米"

#. ~ Description for {'str': '11mm'}
#: .\at_ammo.json
msgid ""
"A large rifle round almost as large as .50bmg though not nearly as long or "
"heavy it is still a massive round, uses a steel case to help deal with high "
"pressures."
msgstr "一种大型步枪弹，尺寸几乎与.50 BMG相当，虽然长度和重量不及，但仍属巨型弹药，采用钢制弹壳以应对高压。"

#: .\at_ammo.json .\at_ammo_types.json
msgid "12.7x108mm"
msgid_plural "12.7x108mms"
msgstr[0] "12.7x108毫米"

#. ~ Description for {'str': '12.7x108mm'}
#: .\at_ammo.json
msgid ""
"to simplify it is the ruski counterpart to .50 bmg a bit longer but the size"
" is identicle otherwise."
msgstr "简而言之，这是.50 BMG的俄式对应版本，稍长一些，但其他尺寸基本相同。"

#. ~ Description for {'str': '12.7x108mm'}
#: .\at_ammo.json
msgid "fmj variant of the 12.7x108mm round."
msgstr "12.7x108毫米弹的全金属被甲型号。"

#: .\at_ammo.json
msgid ".660 supermagnum"
msgid_plural ".660 supermagnums"
msgstr[0] ".660超级马格南"

#. ~ Description for {'str': '.660 supermagnum'}
#. ~ Description for {'str': '.660 supermagnum H.E.'}
#: .\at_ammo.json
msgid "A large ...handgun? round for killing everything short of a mammoth."
msgstr "一种大型...手枪弹？用于猎杀除猛犸象外的一切目标。"

#: .\at_ammo.json
msgid ".660 supermagnum H.E."
msgid_plural ".660 supermagnum H.E.s"
msgstr[0] ".660超级马格南高爆弹"

#: .\at_ammo.json
msgid ".666 supermagnum +p penatrator"
msgid_plural ".666 supermagnum +p penatrators"
msgstr[0] ".666超级马格南+P穿甲弹"

#. ~ Description for {'str': '.666 supermagnum +p penatrator'}
#: .\at_ammo.json
msgid "A large ...handgun? round for killing everything including a mammoth."
msgstr "一种大型...手枪弹？用于猎杀包括猛犸象在内的一切目标。"

#: .\at_ammo.json
msgid "14.5x46mm ball"
msgid_plural "14.5x46mm balls"
msgstr[0] "14.5x46毫米普通弹"

#. ~ Description for {'str': '14.5x46mm ball'}
#: .\at_ammo.json
msgid ""
"A medium low-velocity shell still very large compared to other ammunition."
msgstr "一种中低速炮弹，与其他弹药相比仍属非常大型。"

#: .\at_ammo.json
msgid "14.5x46mm +p"
msgid_plural "14.5x46mm +ps"
msgstr[0] "14.5x46毫米+P弹"

#. ~ Description for {'str': '14.5x46mm +p'}
#: .\at_ammo.json
msgid ""
"A medium low-velocity shell still very large compared to other ammunition, "
"this one has a increased powder load."
msgstr "一种中低速炮弹，与其他弹药相比仍属非常大型，这种型号增加了装药量。"

#: .\at_ammo.json
msgid "14.5x46mm incendiary"
msgid_plural "14.5x46mm incendiarys"
msgstr[0] "14.5x46毫米燃烧弹"

#. ~ Description for {'str': '14.5x46mm incendiary'}
#: .\at_ammo.json
msgid ""
"A medium low-velocity shell still very large compared to other ammunition "
"this one lights a small area on fire."
msgstr "一种中低速炮弹，与其他弹药相比仍属非常大型，这种型号能点燃小片区域。"

#: .\at_ammo.json
msgid "14.5x46mm frag"
msgid_plural "14.5x46mm frags"
msgstr[0] "14.5x46毫米破片弹"

#. ~ Description for {'str': '14.5x46mm frag'}
#: .\at_ammo.json
msgid ""
"A low-velocity shell still very large compared to other ammunition, this one"
" causes fragmentation."
msgstr "与其他弹药相比，这种低速炮弹仍然非常巨大，会造成破片杀伤。"

#: .\at_ammo.json
msgid "33x308mm ball"
msgid_plural "33x308mm balls"
msgstr[0] "33x308毫米普通弹"

#. ~ Description for {'str': '33x308mm ball'}
#: .\at_ammo.json
msgid ""
"A large hypervelocity-shell over twice the size of a .50 browning machinegun"
" round and many times as heavy."
msgstr "一种大型超高速炮弹，尺寸是.50勃朗宁机枪弹的两倍多，重量更是数倍。"

#: .\at_ammo.json
msgid "33x308mm tracer"
msgid_plural "33x308mm tracers"
msgstr[0] "33x308毫米曳光弹"

#. ~ Description for {'str': '33x308mm tracer'}
#: .\at_ammo.json
msgid ""
"A large hypervelocity-shell this one wont emit any smoke and might light "
"things on fire."
msgstr "一种大型超高速炮弹，这种不会产生烟雾，并可能引燃物体。"

#: .\at_ammo.json
msgid "33x308mm high velocity explosive"
msgid_plural "33x308mm high velocity explosives"
msgstr[0] "33x308毫米高速爆破弹"

#. ~ Description for {'str': '33x308mm high velocity explosive'}
#: .\at_ammo.json
msgid "A large hypervelocity-shell this one is made for extreme penatration."
msgstr "一种大型超高速炮弹，专为极端穿透力而设计。"

#: .\at_ammo.json
msgid "33x308mm high explosive"
msgid_plural "33x308mm high explosives"
msgstr[0] "33x308毫米高爆弹"

#. ~ Description for {'str': '33x308mm high explosive'}
#: .\at_ammo.json
msgid ""
"A large explosive-shell about twice the size of a .50 browning machinegun "
