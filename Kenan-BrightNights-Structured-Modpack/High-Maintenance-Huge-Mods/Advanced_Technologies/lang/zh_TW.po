#: .\at_ammo.json
msgid "6x36mm"
msgid_plural "6x36mms"
msgstr[0] "6x36毫米"

#. ~ Description for {'str': '6x36mm'}
#: .\at_ammo.json
msgid ""
"A small prototype round for the military's 'low-power, high-capacity' "
"applications, this particular round was designed for testing in weapons "
"primarily used while mounted."
msgstr "一種為軍方'低威力、高容量'應用設計的小型原型彈藥，這種特殊彈藥主要用於測試安裝在載具上的武器。"

#: .\at_ammo.json .\at_ammo_types.json
msgid "11mm"
msgid_plural "11mms"
msgstr[0] "11毫米"

#. ~ Description for {'str': '11mm'}
#: .\at_ammo.json
msgid ""
"A large rifle round almost as large as .50bmg though not nearly as long or "
"heavy it is still a massive round, uses a steel case to help deal with high "
"pressures."
msgstr "一種大型步槍彈，尺寸幾乎與.50 BMG相當，雖然長度和重量不及，但仍屬巨型彈藥，採用鋼製彈殼以應對高壓。"

#: .\at_ammo.json .\at_ammo_types.json
msgid "12.7x108mm"
msgid_plural "12.7x108mms"
msgstr[0] "12.7x108毫米"

#. ~ Description for {'str': '12.7x108mm'}
#: .\at_ammo.json
msgid ""
"to simplify it is the ruski counterpart to .50 bmg a bit longer but the size"
" is identicle otherwise."
msgstr "簡而言之，這是.50 BMG的俄式對應版本，稍長一些，但其他尺寸基本相同。"

#. ~ Description for {'str': '12.7x108mm'}
#: .\at_ammo.json
msgid "fmj variant of the 12.7x108mm round."
msgstr "12.7x108毫米彈的全金屬被甲型號。"

#: .\at_ammo.json
msgid ".660 supermagnum"
msgid_plural ".660 supermagnums"
msgstr[0] ".660超級馬格南"

#. ~ Description for {'str': '.660 supermagnum'}
#. ~ Description for {'str': '.660 supermagnum H.E.'}
#: .\at_ammo.json
msgid "A large ...handgun? round for killing everything short of a mammoth."
msgstr "一種大型...手槍彈？用於獵殺除猛獁象外的一切目標。"

#: .\at_ammo.json
msgid ".660 supermagnum H.E."
msgid_plural ".660 supermagnum H.E.s"
msgstr[0] ".660超級馬格南高爆彈"

#: .\at_ammo.json
msgid ".666 supermagnum +p penatrator"
msgid_plural ".666 supermagnum +p penatrators"
msgstr[0] ".666超級馬格南+P穿甲彈"

#. ~ Description for {'str': '.666 supermagnum +p penatrator'}
#: .\at_ammo.json
msgid "A large ...handgun? round for killing everything including a mammoth."
msgstr "一種大型...手槍彈？用於獵殺包括猛獁象在內的一切目標。"

#: .\at_ammo.json
msgid "14.5x46mm ball"
msgid_plural "14.5x46mm balls"
msgstr[0] "14.5x46毫米普通彈"

#. ~ Description for {'str': '14.5x46mm ball'}
#: .\at_ammo.json
msgid ""
"A medium low-velocity shell still very large compared to other ammunition."
msgstr "一種中低速炮彈，與其他彈藥相比仍屬非常大型。"

#: .\at_ammo.json
msgid "14.5x46mm +p"
msgid_plural "14.5x46mm +ps"
msgstr[0] "14.5x46毫米+P彈"

#. ~ Description for {'str': '14.5x46mm +p'}
#: .\at_ammo.json
msgid ""
"A medium low-velocity shell still very large compared to other ammunition, "
"this one has a increased powder load."
msgstr "一種中低速炮彈，與其他彈藥相比仍屬非常大型，這種型號增加了裝藥量。"

#: .\at_ammo.json
msgid "14.5x46mm incendiary"
msgid_plural "14.5x46mm incendiarys"
msgstr[0] "14.5x46毫米燃燒彈"

#. ~ Description for {'str': '14.5x46mm incendiary'}
#: .\at_ammo.json
msgid ""
"A medium low-velocity shell still very large compared to other ammunition "
"this one lights a small area on fire."
msgstr "一種中低速炮彈，與其他彈藥相比仍屬非常大型，這種型號能點燃小片區域。"

#: .\at_ammo.json
msgid "14.5x46mm frag"
msgid_plural "14.5x46mm frags"
msgstr[0] "14.5x46毫米破片彈"

#. ~ Description for {'str': '14.5x46mm frag'}
#: .\at_ammo.json
msgid ""
"A low-velocity shell still very large compared to other ammunition, this one"
" causes fragmentation."
msgstr "與其他彈藥相比，這種低速炮彈仍然非常巨大，會造成破片殺傷。"

#: .\at_ammo.json
msgid "33x308mm ball"
msgid_plural "33x308mm balls"
msgstr[0] "33x308毫米普通彈"

#. ~ Description for {'str': '33x308mm ball'}
#: .\at_ammo.json
msgid ""
"A large hypervelocity-shell over twice the size of a .50 browning machinegun"
