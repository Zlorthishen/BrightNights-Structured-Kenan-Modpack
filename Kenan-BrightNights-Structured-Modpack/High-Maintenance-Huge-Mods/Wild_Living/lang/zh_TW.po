msgid_plural "a-frame backpacks"
msgstr[0] "A型框架揹包"

#. ~ Description for {'str': 'a-frame backpack'}
#: .\aframebackpack.json .\aframes.json
msgid "An A-Frame backpack made from heavy sticks. This is just the frame"
msgstr "一個由粗重木棍製成的A型框架揹包。這只是框架部分。"

