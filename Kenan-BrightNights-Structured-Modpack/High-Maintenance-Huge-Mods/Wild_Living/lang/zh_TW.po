#: .\aframebackpack.json .\aframes.json
msgid "looped cordage pouch"
msgid_plural "looped cordage pouchs"
msgstr[0] "環形繩索袋"

#. ~ Description for {'str': 'looped cordage pouch'}
#: .\aframebackpack.json
msgid ""
"A net bag made from carefully looped natural cordage, very flexible, has a "
"strap to wear over your torso"
msgstr "一個由精心編織的天然繩索製成的網袋，非常柔韌，配有可斜挎在身上的揹帶。"

#: .\aframebackpack.json .\aframes.json
msgid "birchbark pouch"
msgid_plural "birchbark pouchs"
msgstr[0] "樺樹皮袋"

#. ~ Description for {'str': 'birchbark pouch'}
#: .\aframebackpack.json
