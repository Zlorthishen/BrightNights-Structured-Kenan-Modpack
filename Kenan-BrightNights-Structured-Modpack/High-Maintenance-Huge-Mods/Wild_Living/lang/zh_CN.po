#: .\evaporation_bowl.json
msgid "clay evaporation dish"
msgid_plural "clay evaporation dishs"
msgstr[0] "陶制蒸发皿"

#. ~ Description for {'str': 'clay evaporation dish'}
#: .\evaporation_bowl.json
msgid ""
"A very large shallow bowl with a lid used for evaporating water. Holds about"
" 20 litres, probably best used with a charcoal smoker."
msgstr "一个带盖的极大浅碗，用于蒸发水分。容量约20升，最好搭配炭火熏炉使用。"

#: .\evaporation_bowl.json
msgid "clay evaporation dish (salt water)"
msgid_plural "clay evaporation dish (salt water)s"
msgstr[0] "陶制蒸发皿（盐水）"

#. ~ Description for {'str': 'clay evaporation dish (salt water)'}
#: .\evaporation_bowl.json
msgid ""
"A very large shallow bowl with a lid used for evaporating water. This one is"
" full of salt water and ready to be heated in a smoking rack"
msgstr "一个带盖的极大浅碗，用于蒸发水分。这个碗装满了盐水，已准备好在熏架上加热。"

#: .\evaporation_bowl.json
msgid "clay evaporation dish (starch water)"
msgid_plural "clay evaporation dish (starch water)s"
msgstr[0] "陶制蒸发皿（淀粉水）"

#. ~ Description for {'str': 'clay evaporation dish (starch water)'}
#: .\evaporation_bowl.json
msgid ""
"A very large shallow bowl with a lid used for evaporating water. This one is"
" full of starch water and ready to be heated in a smoking rack"
msgstr "一个带盖的极大浅碗，用于蒸发水分。这个碗装满了淀粉水，已准备好在熏架上加热。"

#: .\evaporation_bowl.json
msgid "clay evaporation dish (salt)"
msgid_plural "clay evaporation dish (salt)s"
msgstr[0] "陶制蒸发皿（盐）"

#. ~ Description for {'str': 'clay evaporation dish (salt)'}
#: .\evaporation_bowl.json
msgid ""
"A very large shallow bowl with a lid used for evaporating water. This one is"
" full of salt. you can take it apart now"
msgstr "一个带盖的极大浅碗，用于蒸发水分。这个碗装满了盐。你现在可以将其拆解了。"

#: .\evaporation_bowl.json
msgid "clay evaporation dish (flour)"
msgid_plural "clay evaporation dish (flour)s"
msgstr[0] "陶制蒸发皿（面粉）"

#. ~ Description for {'str': 'clay evaporation dish (flour)'}
#: .\evaporation_bowl.json
msgid ""
"A very large shallow bowl with a lid used for evaporating water. This one is"
" full of dried out flour, you can take it apart now"
msgstr "一个带盖的极大浅碗，用于蒸发水分。这个碗装满了干面粉，你现在可以将其拆解了。"

#: .\flint-drill.json
msgid "flint hand drill"
msgid_plural "flint hand drills"
msgstr[0] "燧石手钻"

#. ~ Description for {'str': 'flint hand drill'}
#: .\flint-drill.json
msgid ""
"A primitive bulky manual drill with a flint flake for a drill bit.  Powered "
"by a bow drill, it will tire you quickly."
msgstr "一种原始笨重的手动钻，以燧石片作为钻头。由弓钻驱动，会很快使你疲劳。"

#: .\fur-backpack.json
msgid "fur backpack"
msgid_plural "fur backpacks"
msgstr[0] "毛皮背包"

#. ~ Description for {'str': 'fur backpack'}
#: .\fur-backpack.json
msgid "A medium sized fur backpack, with a few loops for attaching gear."
msgstr "一个中等大小的毛皮背包，带有几个用于挂载装备的环扣。"

#: .\hedgerows.json
msgid "underbrush"
msgstr "下层灌丛"

#. ~ Description for underbrush
#: .\hedgerows.json
msgid ""
"A shoulder high hedgerow.  An observant forager could obtain edible plants, "
"acorns, eggs, and mushrooms from it."
msgstr "一个齐肩高的树篱。细心的采集者可以从中获取可食用植物、橡子、鸡蛋和蘑菇。"

#: .\hedgerows.json
msgid "crunch."
msgstr "嘎吱声。"

#: .\hedgerows.json
msgid "brush."
msgstr "灌木丛。"

