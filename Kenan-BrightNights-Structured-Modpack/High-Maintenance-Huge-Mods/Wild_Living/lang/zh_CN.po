msgid_plural "short leather cords"
msgstr[0] "短皮革绳"

#. ~ Description for {'str': 'short leather cord'}
#: .\leather-intermediates.json
msgid ""
"A 6-inch (or about 15 cm) long piece of rawhide or leather cord.  Useful for"
" some purposes, but not as strong or flexible as proper string."
msgstr "一根6英寸（约15厘米）长的生皮或皮革绳。适用于某些用途，但不如合适的绳子牢固或柔韧。"

#: .\leather-intermediates.json
msgid "long leather cord"
msgid_plural "long leather cords"
msgstr[0] "长皮革绳"

#. ~ Description for {'str': 'long leather cord'}
#: .\leather-intermediates.json
msgid ""
"A 3-foot (or about 90 cm) long piece of rawhide or leather cord.  Useful for"
" some purposes, but not as strong or flexible as proper string."
msgstr "一根3英尺（约90厘米）长的生皮或皮革绳。适用于某些用途，但不如合适的绳子牢固或柔韧。"

