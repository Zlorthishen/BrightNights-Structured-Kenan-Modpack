#: .\aframebackpack.json .\aframes.json
msgid "looped cordage pouch"
msgid_plural "looped cordage pouchs"
msgstr[0] "环形绳索袋"

#. ~ Description for {'str': 'looped cordage pouch'}
#: .\aframebackpack.json
msgid ""
"A net bag made from carefully looped natural cordage, very flexible, has a "
"strap to wear over your torso"
msgstr "一个由精心编织的天然绳索制成的网袋，非常柔韧，配有可斜挎在身上的背带。"

#: .\aframebackpack.json .\aframes.json
msgid "birchbark pouch"
msgid_plural "birchbark pouchs"
msgstr[0] "桦树皮袋"

#. ~ Description for {'str': 'birchbark pouch'}
#: .\aframebackpack.json
msgid ""
"A bag made from cut and woven strips of birchbark, not very flexible, has a "
"bone tog for fastening it closed, has a strap to wear over your torso"
msgstr "一个由切割并编织的桦树皮条制成的袋子，不太柔韧，配有骨扣用于封口，并有可斜挎在身上的背带。"

#: .\aframebackpack.json .\aframes.json
msgid "a-frame backpack"
msgid_plural "a-frame backpacks"
msgstr[0] "A型框架背包"

#. ~ Description for {'str': 'a-frame backpack'}
#: .\aframebackpack.json .\aframes.json
msgid "An A-Frame backpack made from heavy sticks. This is just the frame"
msgstr "一个由粗重木棍制成的A型框架背包。这只是框架部分。"

#: .\aframebackpack.json .\aframes.json
msgid "a-frame birchbark backpack"
msgid_plural "a-frame birchbark backpacks"
msgstr[0] "A型框架桦树皮背包"

#. ~ Use action holster_msg for {'str': 'a-frame birchbark backpack'}.
#. ~ Use action holster_msg for {'str': 'a-frame cordage backpack'}.
#. ~ Use action holster_msg for {'str': 'fur backpack'}.
#: .\aframebackpack.json .\aframes.json .\fur-backpack.json
msgid "You attach your %s to your %s"
msgstr "你将你的%s连接到你的%s上。"

#. ~ Use action holster_prompt for {'str': 'a-frame birchbark backpack'}.
#. ~ Use action holster_prompt for {'str': 'a-frame cordage backpack'}.
#. ~ Use action holster_prompt for {'str': 'fur backpack'}.
#: .\aframebackpack.json .\aframes.json .\fur-backpack.json
msgid "Attach what to backpack loop?"
msgstr "将什么连接到背包环上？"

#. ~ Description for {'str': 'a-frame birchbark backpack'}
#: .\aframebackpack.json
msgid ""
"An A-Frame backpack with a birchbark pouch fastened to it for storage. It "
"has some loops for attaching gear"
msgstr "一个A型框架背包，附有一个桦树皮袋用于储存物品。它有一些环扣可以挂载装备。"

#: .\aframebackpack.json
msgid "a-frame cordage backpack"
msgid_plural "a-frame cordage backpacks"
msgstr[0] "A型绳索背包"

#. ~ Description for {'str': 'a-frame cordage backpack'}
#: .\aframebackpack.json
msgid ""
"An A-Frame backpack with a looped cordage pouch fastened to it for storage. "
"It has some loops for attaching gear"
msgstr "一个A型框架背包，附有一个环状绳索袋用于储存物品。它有一些环扣可以挂载装备。"

#. ~ Description for {'str': 'looped cordage pouch'}
#: .\aframes.json
msgid ""
"A net bag made from carefully looped natural cordage, has a strap to wear "
"over your torso"
msgstr "一个由精心编织的天然绳索制成的网袋，配有背带可斜挎在躯干上。"

#. ~ Description for {'str': 'birchbark pouch'}
#: .\aframes.json
msgid ""
"A bag made from cut and woven strips of birchbark, has a bone tog for "
"fastening it closed, has a strap to wear over your torso"
msgstr "一个由切割并编织的桦树皮条制成的袋子，配有骨制扣件用于封口，并有背带可斜挎在躯干上。"

#. ~ Description for {'str': 'a-frame birchbark backpack'}
#: .\aframes.json
msgid ""
"An A-Frame backpack with a birchbark pouch fastened to it for storage. There"
" is a small loop for carrying am axe or similar"
msgstr "一个A型框架背包，附有一个桦树皮袋用于储存物品。有一个小环扣可用于携带斧头或类似工具。"

#. ~ Description for {'str': 'a-frame birchbark backpack'}
#: .\aframes.json
msgid ""
"An A-Frame backpack with a looped cordage pouch fastened to it for storage. "
"There is a small loop for carrying am axe or similar"
msgstr "一个A型框架背包，附有一个环状绳索袋用于储存物品。有一个小环扣可用于携带斧头或类似工具。"

#: .\birch.json
msgid "birch water jug"
msgid_plural "birch water jugs"
msgstr[0] "桦树水壶"

#. ~ Description for {'str': 'birch water jug'}
#: .\birch.json
msgid ""
"A carefully made birch bark water jug with a lid, it is sealed with pine "
"pitch. It can hold 1.5 liters of water."
msgstr "一个精心制作的桦树皮水壶，带有盖子，并用松脂密封。它可以容纳1.5升水。"

#: .\birch.json
msgid "birch funnel"
msgid_plural "birch funnels"
msgstr[0] "桦树漏斗"

#. ~ Use action done_message for {'str': 'birch funnel'}.
#: .\birch.json
msgid "You place the birch funnel, waiting to collect rain."
msgstr "你放置了桦树漏斗，等待收集雨水。"

#. ~ Description for {'str': 'birch funnel'}
#: .\birch.json
msgid ""
"This is a small, birchbark funnel used to collect rainwater.  Use it outside"
" and place a container beneath it to collect water when it rains."
msgstr "这是一个用于收集雨水的小型桦树皮漏斗。在室外使用它，并在下方放置容器，以便下雨时收集水。"

#: .\birch.json
msgid "birchbark funnel"
msgstr "桦树皮漏斗"

#: .\bone-pickaxe.json
msgid "bone pickaxe"
msgid_plural "bone pickaxes"
msgstr[0] "骨制镐"

#. ~ Description for {'str': 'bone pickaxe'}
#: .\bone-pickaxe.json
msgid ""
"This is a primitive pickaxe, traditionally made from antler or bone, and "
"fire-hardened for greater hardness.  It will wear out with use, but still "
"suitable for striking the earth."
msgstr "这是一把原始的镐，传统上由鹿角或骨头制成，并通过火烤硬化以提高硬度。它会随着使用而磨损，但仍适合挖掘土地。"

#: .\clay-container-overrides.json
msgid "large clay pot"
msgid_plural "large clay pots"
msgstr[0] "大陶罐"

#. ~ Description for {'str': 'large clay pot'}
#: .\clay-container-overrides.json
msgid ""
"A bulky and heavy clay pot with a waterproofed lid, meant to store water, "
"but can carry other liquids in a pinch."
msgstr "一个笨重的大陶罐，带有防水盖子，主要用于储水，但紧急情况下也可携带其他液体。"

