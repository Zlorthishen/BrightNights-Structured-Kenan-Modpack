#: .\books.json
msgid "Portal Shard Combat Applications"
msgid_plural "Portal Shard Combat Applications"
msgstr[0] "傳送門碎片戰鬥應用"

#. ~ Description for {'str': 'Portal Shard Combat Applications', 'str_pl':
#. 'Portal Shard Combat Applications'}
#: .\books.json
msgid ""
"This large Rivtech manual has been marked for destruction, almost everything"
" in it but the technical specification sections and blueprints blacked out "
"and unreadable."
msgstr "這本大型Rivtech手冊已被標記為待銷燬，其中除了技術規格部分和藍圖外，幾乎所有內容都被塗黑且無法閱讀。"

#: .\crystal-shard.json
msgid "crystal shard"
msgid_plural "crystal shards"
msgstr[0] "水晶碎片"

#. ~ Description for {'str': 'crystal shard'}
#: .\crystal-shard.json
msgid ""
"A shard of crystal that shimmers like the stars and vibrates in your hand "
"when you grasp it."
msgstr "一片如星辰般閃爍的水晶碎片，握在手中時會微微振動。"

#: .\low-level.json
msgid "beam sword controls"
msgid_plural "beam sword controlss"
msgstr[0] "光束劍控制裝置"

#. ~ Description for {'str': 'beam sword controls'}
#: .\low-level.json
msgid "The activation controls for a Rivtech beam sword."
msgstr "Rivtech光束劍的激活控制裝置。"

#: .\low-level.json
msgid "beam sword power cell"
msgid_plural "beam sword power cells"
msgstr[0] "光束劍能量單元"

#. ~ Description for {'str': 'beam sword power cell'}
#: .\low-level.json
msgid "A heavy power cell used to ignite a Rivtech beam sword."
msgstr "用於點燃 Rivtech 光束劍的重型能量單元。"

#: .\low-level.json
msgid "beam sword portal conductor"
msgid_plural "beam sword portal conductors"
msgstr[0] "光束劍傳送場導體"

#. ~ Description for {'str': 'beam sword portal conductor'}
#: .\low-level.json
msgid "The portal field conductor used in a Rivtech beam sword."
msgstr "Rivtech 光束劍中使用的傳送場導體。"

#: .\low-level.json
msgid "beam sword vortex ring"
msgid_plural "beam sword vortex rings"
msgstr[0] "光束劍渦流環"

#. ~ Description for {'str': 'beam sword vortex ring'}
#: .\low-level.json
msgid ""
"An extremely delicate yet complex set of interlocking cogs used to help "
"power a Rivtech beam sword."
msgstr "一套極其精密而複雜的互鎖齒輪組，用於協助為 Rivtech 光束劍供能。"

#: .\low-level.json
msgid "beam sword power insulator"
msgid_plural "beam sword power insulators"
msgstr[0] "光束劍能量絕緣體"

#. ~ Description for {'str': 'beam sword power insulator'}
#: .\low-level.json
msgid "A ceramic power shielding unit from a Rivtech beam sword."
msgstr "來自 Rivtech 光束劍的陶瓷能量屏蔽單元。"

#: .\low-level.json
msgid "beam sword energy gate"
msgid_plural "beam sword energy gates"
msgstr[0] "光束劍能量門"

#. ~ Description for {'str': 'beam sword energy gate'}
#: .\low-level.json
msgid ""
"A light absorbing case of shimmering, slow moving liquid used to guide power"
" in Rivtech beam sword."
msgstr "一個吸收光線的外殼，內含閃爍、緩慢流動的液體，用於引導 Rivtech 光束劍中的能量。"

#: .\low-level.json
msgid "beam sword recharge socket"
msgid_plural "beam sword recharge sockets"
msgstr[0] "光束劍充電接口"

#. ~ Description for {'str': 'beam sword recharge socket'}
#: .\low-level.json
msgid "Power connection ports to be installed in a Rivtech beam sword."
msgstr "需安裝在 Rivtech 光束劍上的電源連接端口。"

#: .\low-level.json
msgid "beam sword focusing chamber"
msgid_plural "beam sword focusing chambers"
msgstr[0] "光束劍聚焦腔"

#. ~ Description for {'str': 'beam sword focusing chamber'}
#: .\low-level.json
msgid "A focusing chamber for the blade on a Rivtech beam sword."
msgstr "用於 Rivtech 光束劍劍刃的聚焦腔。"

#: .\low-level.json
msgid "beam sword blade energy channel"
msgid_plural "beam sword blade energy channels"
msgstr[0] "光束劍劍刃能量通道"

#. ~ Description for {'str': 'beam sword blade energy channel'}
#: .\low-level.json
msgid ""
"The energy channel the portal beam passes through on a Rivtech beam sword."
msgstr "Rivtech 光束劍中傳送光束穿過的能量通道。"

#: .\low-level.json
msgid "beam sword cycling field energizer"
msgid_plural "beam sword cycling field energizers"
msgstr[0] "光束劍循環場激發器"

#. ~ Description for {'str': 'beam sword cycling field energizer'}
#: .\low-level.json
msgid ""
"The field energizer that keeps the blade ignited on a Rivtech beam sword."
msgstr "維持 Rivtech 光束劍劍刃點燃的場激發器。"

#: .\low-level.json
msgid "beam sword energy modulation circuit"
msgid_plural "beam sword energy modulation circuits"
msgstr[0] "光束劍能量調製電路"

#. ~ Description for {'str': 'beam sword energy modulation circuit'}
#: .\low-level.json
msgid "An energy modulation circuit for the blade on a Rivtech beam sword."
msgstr "用於 Rivtech 光束劍劍刃的能量調製電路。"

#: .\low-level.json
msgid "beam sword focusing lens"
msgid_plural "beam sword focusing lenss"
msgstr[0] "光束劍聚焦透鏡"

#. ~ Description for {'str': 'beam sword focusing lens'}
#: .\low-level.json
msgid ""
"A lens to help ignite and then focus the blade emitted from a Rivtech beam "
"sword."
msgstr "用於幫助點燃並聚焦 Rivtech 光束劍所發射劍刃的透鏡。"

#: .\low-level.json
msgid "beam sword emitter matrix"
msgid_plural "beam sword emitter matrixs"
msgstr[0] "光束劍發射器矩陣"

#. ~ Description for {'str': 'beam sword emitter matrix'}
#: .\low-level.json
msgid ""
"A highly dangerous component of a Rivtech beam sword used to keep the blade "
"from igniting the atmosphere."
msgstr "Rivtech 光束劍中一個高度危險的組件，用於防止劍刃點燃大氣。"

#: .\low-level.json
msgid "beam sword high energy flux aperture"
msgid_plural "beam sword high energy flux apertures"
msgstr[0] "光束劍高能通量孔徑"

#. ~ Description for {'str': 'beam sword high energy flux aperture'}
#: .\low-level.json
msgid ""
"A series of ever-looping circuity from a Rivtech beam sword that hurts your "
"eyes to try and trace."
msgstr "來自 Rivtech 光束劍的一系列不斷循環的電路，試圖追蹤它會傷害你的眼睛。"

#: .\melee.json
msgid "rivtech beam sword"
msgid_plural "rivtech beam swords"
msgstr[0] "Rivtech 光束劍"

#. ~ Description for {'str': 'rivtech beam sword'}
#: .\melee.json
msgid "Totally not a lightsaber."
msgstr "絕對不是光劍。"

#: .\modinfo.json
msgid "Rivtech Beam Swords"
msgstr "Rivtech 光束劍"

#. ~ Description for Rivtech Beam Swords
#: .\modinfo.json
msgid "Adds the Rivtech beam sword, a powerful constructible endgame weapon."
msgstr "添加了 Rivtech 光束劍，一種強大的可製作終局武器。"

#: .\top-level.json
msgid "beam sword outer casing"
msgid_plural "beam sword outer casings"
msgstr[0] "光束劍外殼"

#. ~ Description for {'str': 'beam sword outer casing'}
#: .\top-level.json
msgid "The outer casing for a Rivtech beam sword."
msgstr "Rivtech光束劍的外殼。"

#: .\top-level.json
msgid "beam sword power assembly"
msgid_plural "beam sword power assemblys"
msgstr[0] "光束劍動力組件"

#. ~ Description for {'str': 'beam sword power assembly'}
#: .\top-level.json
msgid "The completed power assembly for a Rivtech beam sword."
msgstr "Rivtech光束劍的完整動力組件。"

#: .\top-level.json
msgid "beam sword focusing assembly"
msgid_plural "beam sword focusing assemblies"
msgstr[0] "光束劍聚焦組件"

#. ~ Description for {'str': 'beam sword focusing assembly', 'str_pl': 'beam
#. sword focusing assemblies'}
#: .\top-level.json
msgid "The completed focusing assembly for a Rivtech beam sword."
msgstr "Rivtech光束劍的完整聚焦組件。"

#: .\top-level.json
msgid "beam sword blade emitter"
msgid_plural "beam sword blade emitters"
msgstr[0] "光束劍劍刃發射器"

#. ~ Description for {'str': 'beam sword blade emitter'}
#: .\top-level.json
msgid "The blade emitter for a Rivtech beam sword."
msgstr "Rivtech光束劍的劍刃發射器。"
