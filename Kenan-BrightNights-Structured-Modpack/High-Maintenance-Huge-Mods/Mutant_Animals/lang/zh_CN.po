#: .\harvest.json
msgid "This animal is covered in thick layers of blubber."
msgstr "这只动物覆盖着厚厚的脂肪层。"

#: .\harvest.json
msgid "This strange animal has metal bones."
msgstr "这只奇怪的动物长着金属骨骼。"

#: .\items_egg.json
msgid "bird egg"
msgid_plural "bird eggs"
msgstr[0] "鸟蛋"

#. ~ Description for {'str': 'bird egg'}
#: .\items_egg.json
msgid "Nutritious egg laid by a bird."
msgstr "鸟类产下的营养丰富的蛋。"

#: .\items_egg.json
msgid "songbird egg"
msgid_plural "songbird eggs"
msgstr[0] "鸣禽蛋"

#: .\items_egg.json
msgid "vultch egg"
msgid_plural "vultch eggs"
msgstr[0] "秃鹫蛋"

#: .\items_egg.json
msgid "iridescent egg"
msgid_plural "iridescent eggs"
msgstr[0] "虹彩蛋"

#: .\items_egg.json
msgid "ghoul bird egg"
msgid_plural "ghoul bird eggs"
msgstr[0] "食尸鸟蛋"

#. ~ Description for {'str': 'ghoul bird egg'}
#: .\items_egg.json
msgid "Poisonous egg laid by a bird."
msgstr "鸟类产下的有毒蛋。"

#: .\items_egg.json
