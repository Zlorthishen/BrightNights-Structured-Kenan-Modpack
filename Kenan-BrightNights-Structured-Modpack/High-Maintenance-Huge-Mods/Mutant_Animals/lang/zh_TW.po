msgstr "陌生的鳥叫聲。"

#: .\speech.json
msgid "the strange sounds of an alien forest."
msgstr "異域森林的奇異聲響。"

#: .\speech.json
msgid "the weird cries of mutant birds."
msgstr "變異鳥類發出的怪異鳴叫。"

#: .\speech.json
msgid "an unnatural droning sound."
msgstr "一種不自然的嗡嗡聲。"

#: .\speech.json
msgid "the music of a new world."
msgstr "新世界的音樂。"

#: .\speech.json
msgid "piercing cries of an unknown bird."
msgstr "未知鳥類發出的刺耳鳴叫。"

#: .\speech.json
msgid "bird calls, unlike any you've heard before."
msgstr "鳥鳴聲，與你以往聽到的任何聲音都不同。"

#: .\speech.json
msgid "hideous death cries."
msgstr "駭人的死亡哀嚎。"

#: .\speech.json
msgid "hypnotic birdcalls."
msgstr "令人著迷的鳥鳴。"

#: .\speech.json
msgid "\"wlo wlo wlo wlooooowlowlo.\""
msgstr "\"wlo wlo wlo wlooooowlowlo。\""

#: .\speech.json
msgid "\"raaaanrzh raaaanrzh raaaanrzh.\""
msgstr "\"raaaanrzh raaaanrzh raaaanrzh。\""

#: .\speech.json
msgid "\"vrooonoo vroonoo vrooooonoo vroonoo.\""
msgstr "\"vrooonoo vroonoo vrooooonoo vroonoo。\""

#: .\speech.json
msgid "\"bjyoooom bjyoooom bjyoooom.\""
msgstr "\"bjyoooom bjyoooom bjyoooom。\""

#: .\speech.json
msgid "\"Hreeeeeeeech!\""
msgstr "\"Hreeeeeeeech！\""

#: .\speech.json
msgid "\"Auuuuuuwuuu!\""
msgstr "\"Auuuuuuwuuu！\""

#: .\speech.json
msgid "\"Raaaaahaaaaa!\""
msgstr "\"Raaaaahaaaaa！\""

#: .\speech.json
msgid "\"Neeeeeeehuuuuuu!\""
msgstr "\"Neeeeeeehuuuuuu！\""

#: .\speech.json
msgid "\"I could use some help over here.\""
msgstr "\"我這邊需要點幫助。\""

#: .\speech.json
msgid "\"Don't leave me behind.\""
msgstr "\"別丟下我。\""

#: .\speech.json
msgid "\"We've always been friends, right?\""
msgstr "\"我們一直是朋友，對吧？\""

#: .\speech.json
msgid "\"Come closer.\""
msgstr "\"靠近點。\""

#: .\speech.json
msgid "\"Let's team up.\""
msgstr "\"我們組隊吧。\""

#: .\speech.json
msgid "\"Help!  I can't swim!\""
msgstr "\"救命！我不會游泳！\""

#: .\speech.json
msgid "\"Help a guy out, would ya?\""
msgstr "\"幫個忙，好嗎？\""

#: .\speech.json
msgid "\"It's too dark to see.\""
msgstr "\"太黑了，什麼都看不見。\""

#: .\speech.json
msgid "\"Follow me.  I'll show you the way.\""
msgstr "\"跟我來，我給你帶路。\""

#: .\speech.json
msgid "\"We should stick together.\""
msgstr "\"我們應該待在一起。\""
