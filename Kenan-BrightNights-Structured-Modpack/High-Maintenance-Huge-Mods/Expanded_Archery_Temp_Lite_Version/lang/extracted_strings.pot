msgid_plural "high-quality bow strings"
msgstr[0] ""
msgstr[1] ""

#: .\Attachments.json
msgid ""
"A strong and precise polymer string for a bow or crossbow. Helps to keep the"
" bow constant, and retain as much energy as possible. Oddly enough, it's "
"even your favourite color!"
msgstr ""

#: .\Attachments.json
msgid "string"
msgstr ""

