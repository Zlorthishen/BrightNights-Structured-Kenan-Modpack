#: .\items.json
msgid "honeydew"
msgid_plural "honeydews"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'honeydew'}
#: .\items.json
msgid ""
"It's a sugar-rich sticky substance, produced by aphids from plant's sap.  "
"Ants and bees love it."
msgstr ""

#: .\items.json
msgid "antlion egg"
msgid_plural "antlion eggs"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'antlion egg'}
#: .\items.json
msgid "A large white antlion egg.  There is something hard inside."
msgstr ""

#: .\modinfo.json
msgid "Bug's life"
msgstr ""

#. ~ Description for Bug's life
#: .\modinfo.json
msgid "Add new types of insects, such as aphids, mantises, etc."
msgstr ""

#: .\monsters.json
msgid "giant aphid"
msgid_plural "giant aphids"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'giant aphid', 'str_pl': 'giant aphids'}
#: .\monsters.json
msgid ""
"A green aphid about a size of a rabbit.  It is constantly searching for "
"plants to suck from.  Probably you could sate it for a moment with cattle "
"fodder."
msgstr ""

#: .\monsters.json
msgid "huge praying mantis"
msgid_plural "huge praying mantiss"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'huge praying mantis'}
#: .\monsters.json
msgid ""
"A green mutant insect with sharp grappling spikes on it's front legs.  It's "
"a little smaller than an adult person."
msgstr ""

#: .\monsters.json
msgid "giant praying mantis"
msgid_plural "giant praying mantises"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'giant praying mantis', 'str_pl': 'giant praying
#. mantises'}
#: .\monsters.json
msgid ""
"An enormous green creature grown about a size of a bear.  It dances weirdly "
"and ready to chop your head off in any moment."
msgstr ""

#: .\monsters.json
msgid "great mantis"
msgid_plural "great mantises"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'great mantis', 'str_pl': 'great mantises'}
#: .\monsters.json
msgid ""
"This ferocious creature is lurking through the land.  It's probably capable "
"of killing a moose with it's powerful arms."
msgstr ""

#: .\monsters.json
msgid "giant mole cricket"
msgid_plural "giant mole crickets"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'giant mole cricket'}
#: .\monsters.json
msgid ""
"An enormous underground bug.  It's a common garden pest.  Beware ear-"
"splitting screech and strong shovel-like front legs."
msgstr ""

#: .\monsters.json
msgid "giant lady bug"
msgid_plural "giant lady bugs"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'giant lady bug'}
#: .\monsters.json
msgid ""
"A red lady bug covered in black spots about a size of a horse.  Despite cute"
" looks it is a ferocious predator capable of killing swarms of ants and "
"aphids."
msgstr ""

#: .\monsters.json
msgid "huge grasshopper"
msgid_plural "huge grasshoppers"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'huge grasshopper'}
#: .\monsters.json
msgid "A large grasshopper a few times bigger than a regular one."
msgstr ""

#: .\monsters.json
msgid "giant grasshopper"
msgid_plural "giant grasshoppers"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'giant grasshopper', 'str_pl': 'giant
#. grasshoppers'}
#: .\monsters.json
msgid ""
"A huge green grasshopper about a size of a big dog with long and strong back"
" legs.  It hops, it hops and never stops."
msgstr ""

#: .\monsters.json
msgid "giant antlion larva"
msgid_plural "giant antlion larvae"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'giant antlion larva', 'str_pl': 'giant antlion
#. larvae'}
#: .\monsters.json
msgid ""
"This huge grub has powerful mandibles and a hungry look.  It hides in dirt "
"and waits for pray to come clother."
msgstr ""

#: .\monsters.json
msgid "giant adult antlion"
msgid_plural "giant adult antlions"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'giant adult antlion'}
#: .\monsters.json
msgid ""
"A ferocious mutant flying antlion as big as a cat, darting through the air "
"with a cluster of fangs for a mouth."
msgstr ""

#: .\monsters.json
msgid "big water strider"
msgid_plural "big water striders"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'big water strider'}
#: .\monsters.json
msgid ""
"This water bug is a few times bigger, than a reguar one.  It's moves are "
"fast and fluid."
msgstr ""

#: .\monsters.json
msgid "giant water strider"
msgid_plural "giant water striders"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'giant water strider'}
#: .\monsters.json
msgid ""
"This water glider is about as big as a domestic cat.  It's legs are more "
"fin-like and a swollen body is mostly submerged underwater."
msgstr ""
