msgid_plural "Flasks of Cloud Kiss (lethal)"
msgstr[0] "云吻（致命）"

#. ~ Use action activation_message for {'str': 'Cloud Kiss (lethal)',
#. 'str_pl': 'Flasks of Cloud Kiss (lethal)'}.
