msgid_plural "Vera's outfits"
msgstr[0] "薇拉的禮服"

#. ~ Description for {'str': "Vera's outfit"}
#: .\items\clothes.json
msgid ""
"An iconic black evening dress with a red outline worn by the famous Holywood"
