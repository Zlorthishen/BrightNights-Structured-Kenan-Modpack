msgid "fire chitin armor kit"
msgid_plural "fire chitin armor kits"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'fire chitin armor kit'}
#: .\vehicle_parts.json
msgid "Durable fire chitin plating made for a vehicle."
msgstr ""
