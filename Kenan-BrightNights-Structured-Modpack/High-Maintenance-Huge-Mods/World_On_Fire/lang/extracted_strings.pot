#: .\generic.json
msgid "chunk of fire chitin"
msgid_plural "chunks of fire chitin"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'chunk of fire chitin', 'str_pl': 'chunks of fire
#. chitin'}
#: .\generic.json
msgid ""
"A lump of exoskeleton that has a firey-orange sheen to it.  It is fire-"
"resistant, warm to the touch, and remarkably sturdy."
msgstr ""

#: .\harvest.json
msgid "You laboriously dissect the colossal insect."
msgstr ""

#: .\items.json
msgid "pair of fire chitin arm guards"
msgid_plural "pairs of fire chitin arm guards"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'pair of fire chitin arm guards', 'str_pl':
#. 'pairs of fire chitin arm guards'}
#: .\items.json
msgid ""
"A pair of arm guards crafted from the carefully cleaned and pruned "
"exoskeletons of fire ants. Fire-resistant and very durable."
msgstr ""

#: .\items.json
msgid "fire chitin armor"
msgid_plural "fire chitin armors"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'fire chitin armor'}
#: .\items.json
msgid ""
"Leg and body armor crafted from the carefully cleaned and pruned "
"exoskeletons of fire ants. Fire-resistant and very durable."
msgstr ""

#: .\items.json
msgid "pair of fire chitin gauntlets"
msgid_plural "pairs of fire chitin gauntlets"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'pair of fire chitin gauntlets', 'str_pl': 'pairs
#. of fire chitin gauntlets'}
#: .\items.json
msgid ""
"Gauntlets crafted from the carefully cleaned and pruned exoskeletons of fire"
" ants. Fire-resistant and very durable."
msgstr ""

#: .\items.json
msgid "fire chitin helmet"
msgid_plural "fire chitin helmets"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'fire chitin helmet'}
#: .\items.json
msgid ""
"A helmet crafted from the carefully cleaned and pruned exoskeletons of fire "
"ants.  Covers the entire head; fire-resistant and very durable."
msgstr ""

#: .\items.json
msgid "pair of fire chitin boots"
msgid_plural "pairs of fire chitin boots"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'pair of fire chitin boots', 'str_pl': 'pairs of
#. fire chitin boots'}
#: .\items.json
msgid ""
"Boots crafted from carefully cleaned and pruned exoskeletons of fire ants. "
"Fire-resistant and very durable."
msgstr ""

#: .\items.json
msgid "fire ant stinger"
msgid_plural "fire ant stingers"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'fire ant stinger', 'str_pl': 'fire ant
#. stingers'}
#: .\items.json
msgid ""
"Red stinger taken from an fire ant. Left over venom residue might have some "
"effect if a vital is hit. Useful weapon in a pinch, but handling by itself "
"is difficult"
msgstr ""

#: .\items.json
msgid "red stinger knife"
msgid_plural "stinger knives"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'red stinger knife', 'str_pl': 'stinger knives'}
#: .\items.json
msgid ""
"Red stinger taken from an fire ant thats been reinforced with fire chintin "
"into a knife. Left over venom residue might have some effect if a vital is "
"hit."
msgstr ""

#: .\items.json
msgid "red stinger spear"
msgid_plural "fire ant stingers"
msgstr[0] ""
msgstr[1] ""

#. ~ Description for {'str': 'red stinger spear', 'str_pl': 'fire ant
#. stingers'}
#: .\items.json
msgid ""
"Red stinger taken from an fire ant thats been strapped to a stick giving "
"increased reach at cost of durability. Left over venom residue might have "
"some effect if a vital is hit."
msgstr ""

#: .\items.json
msgid "inactive exterminator bot"
msgid_plural "inactive exterminator bots"
msgstr[0] ""
msgstr[1] ""

#. ~ Use action friendly_msg for {'str': 'inactive exterminator bot'}.
#: .\items.json
msgid "The exterminator bot shudders briefly and rolls away."
msgstr ""

#. ~ Use action hostile_msg for {'str': 'inactive exterminator bot'}.
#: .\items.json
msgid ""
"The exterminator detects gross pests in the area, and shines a multitude of "
"colored lights in your face!"
msgstr ""

#. ~ Description for {'str': 'inactive exterminator bot'}
#: .\items.json
msgid ""
"This is an inactive exterminator robot. It resembles a security bot only "
"armed with a flamethrower. Using this item involves placing it on the ground"
" and turning it on.  If reprogrammed and rewired successfully the robot will"
" race towards enemies and torch them alive."
msgstr ""

#: .\items.json
msgid "inactive exterminator tank"
msgid_plural "inactive exterminator tanks"
msgstr[0] ""
msgstr[1] ""

#. ~ Use action friendly_msg for {'str': 'inactive exterminator tank'}.
#: .\items.json
msgid "The exterminator tank shudders briefly and rolls away."
msgstr ""

#. ~ Use action hostile_msg for {'str': 'inactive exterminator tank'}.
#: .\items.json
msgid ""
"The exterminator tank detects gross pests in the area, and shines a "
"multitude of colored lights in your face!"
msgstr ""

#. ~ Description for {'str': 'inactive exterminator tank'}
#: .\items.json
msgid ""
"This is an inactive exterminator tank. It resembles a large tank only armed "
"with a flamethrower & napalm bomb launchers. Using this item involves "
"placing it on the ground and turning it on.  If reprogrammed and rewired "
"successfully the tank will race towards enemies and torch them alive."
msgstr ""

#: .\items.json
msgid "inactive explosive skitterbot"
msgid_plural "inactive explosive skitterbots"
msgstr[0] ""
msgstr[1] ""

#. ~ Use action friendly_msg for {'str': 'inactive explosive skitterbot'}.
#: .\items.json
msgid "The explosive skitterbot shudders briefly and rolls away."
msgstr ""

#. ~ Use action hostile_msg for {'str': 'inactive explosive skitterbot'}.
#: .\items.json
msgid ""
"The explosive skitterbot gives off a loud sharp beep, and shines a multitude"
" of colored lights in your face!"
msgstr ""

#. ~ Description for {'str': 'inactive explosive skitterbot'}
#: .\items.json
msgid ""
"This is an inactive explosive skitterbot. It resembles a dog size insect "
"packed with explosives. Using this item involves placing it on the ground "
"and turning it on.  If reprogrammed and rewired successfully the robot will "
"race towards enemies and explode."
msgstr ""

#: .\items.json
msgid "inactive incendiary skitterbot"
msgid_plural "inactive incendiary skitterbots"
msgstr[0] ""
msgstr[1] ""

#. ~ Use action friendly_msg for {'str': 'inactive incendiary skitterbot'}.
#: .\items.json
msgid "The incendiary skitterbot shudders briefly and rolls away."
msgstr ""

#. ~ Use action hostile_msg for {'str': 'inactive incendiary skitterbot'}.
#: .\items.json
msgid ""
"The incendiary skitterbot gives off a loud sharp beep, and shines a "
"multitude of colored lights in your face!"
msgstr ""

#. ~ Description for {'str': 'inactive incendiary skitterbot'}
#: .\items.json
msgid ""
"This is an inactive incendiary skitterbot. It resembles a dog size insect "
"packed with incendiary explosives. Using this item involves placing it on "
"the ground and turning it on.  If reprogrammed and rewired successfully the "
"robot will race towards enemies and explode."
msgstr ""

