msgid ".380"
msgid_plural ".380"
msgstr[0] ".380"

#. ~ Description for {'str': '.380', 'str_pl': '.380'}
#: .\art_ammo.json
msgid ""
"The .380 round is a compact pistol round. Only used in compact pistols or "
"zip guns."
msgstr ".380子彈是一種緊湊型手槍彈。僅用於緊湊型手槍或簡易槍械。"

