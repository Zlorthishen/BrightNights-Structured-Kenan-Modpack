msgid_plural "jet hammer (on)s"
msgstr[0] "噴氣錘（開啟）"

#. ~ Use action msg for {'str': 'jet hammer (on)'}.
#: .\ver_weapons.json
msgid "The jet hammer fizzles and goes quiet."
msgstr "噴氣錘嘶嘶作響後歸於寂靜。"

#. ~ Description for {'str': 'jet hammer (on)'}
#: .\ver_weapons.json
msgid ""
"The jet hammer rumbles and revs. It is still quite unwieldy and unbalanced. "
"Make a mess. Activate to turn off."
msgstr "噴氣錘轟鳴並加速。它仍然相當笨重且不平衡。製造混亂。激活以關閉。"

#: .\ver_weapons.json
msgid "Absolute Reaper"
