#. ~ Description for {'str': 'crated labrador mutt'}
#: .\items\dog_items_crate.json
msgid ""
"A Labrador Retriever in a crate.  You can train it as an attack dog or "
"release it from the crate."
msgstr "笼中的拉布拉多寻回犬。你可以将其训练为攻击犬，或从笼中释放。"

#: .\items\dog_items_crate.json
msgid "crated attack labrador"
msgid_plural "crated attack labradors"
msgstr[0] "笼中攻击型拉布拉多犬"

#. ~ Description for {'str': 'crated attack labrador'}
#: .\items\dog_items_crate.json
msgid ""
"An attack Labrador Retriever in a crate.  You can release it from the crate."
msgstr "笼中的攻击型拉布拉多寻回犬。你可以将其从笼中释放。"

#: .\items\dog_items_crate.json
msgid "crated bulldog"
msgid_plural "crated bulldogs"
msgstr[0] "笼中斗牛犬"

