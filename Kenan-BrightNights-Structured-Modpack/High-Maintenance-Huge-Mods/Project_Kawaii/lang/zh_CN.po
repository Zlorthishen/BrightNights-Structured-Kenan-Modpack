#: .\AMTS_items.json
msgid "<color_pink>[AMTS]</color> Receiver"
msgid_plural "<color_pink>[AMTS]</color> Receivers"
msgstr[0] "<color_pink>[AMTS]</color> 接收器"

#. ~ Description for {'str': '<color_pink>[AMTS]</color> Receiver'}
#: .\AMTS_items.json
msgid ""
"Use this to send a request for an item from the A&M dimensional transfer "
"system."
msgstr "使用此设备可从 A&M 维度传输系统请求物品。"

#: .\AMTS_items.json
msgid "<color_pink>[AMTS]</color> Transmitter"
msgid_plural "<color_pink>[AMTS]</color> Transmitters"
msgstr[0] "<color_pink>[AMTS]</color> 发射器"

#. ~ Description for {'str': '<color_pink>[AMTS]</color> Transmitter'}
#: .\AMTS_items.json
msgid ""
"Use this to send away an item to the A&M dimensional transfer system in "
"exchange for points."
msgstr "使用此设备可将物品发送至 A&M 维度传输系统以换取点数。"

#: .\AMTS_items.json
msgid "<color_pink>[AMTS]</color> Point"
msgid_plural "<color_pink>[AMTS]</color> Points"
msgstr[0] "<color_pink>[AMTS]</color> 点数器"

#. ~ Description for {'str': '<color_pink>[AMTS]</color> Point', 'str_pl':
#. '<color_pink>[AMTS]</color> Points'}
#: .\AMTS_items.json
msgid ""
"This device allows you to see how much currency you've accumulated for use "
"with the A&M dimensional transfer system."
msgstr "此设备可让你查看为使用 A&M 维度传输系统所累积的货币数量。"

#: .\AMTS_items.json
msgid "<color_pink>[AMTS]</color> Packaging System"
msgid_plural "<color_pink>[AMTS]</color> Packaging Systems"
msgstr[0] "<color_pink>[AMTS]</color> 打包系统"

#. ~ Description for {'str': '<color_pink>[AMTS]</color> Packaging System'}
#: .\AMTS_items.json
msgid ""
"This is a packaging system for use with the A&M dimensional transfer system."
" It can be used to compress raw material into a single package which can be "
"sent to the AMTS in exchange for points."
msgstr "这是用于 A&M 维度传输系统的打包系统。它可以将原材料压缩成单个包裹，发送至 AMTS 以换取点数。"

#: .\AMTS_items.json
msgid "[AMTS] Compressed Matter Package (logs x3)"
msgid_plural "[AMTS] Compressed Matter Packages (logs x3)"
msgstr[0] "[AMTS] 压缩物质包裹（原木 x3）"

