#: .\AMTS_items.json
msgid "Cute High Capacity UPS"
msgid_plural "Cute High Capacity UPSs"
msgstr[0] "可爱高容量UPS"

#. ~ Description for {'str': 'Cute High Capacity UPS'}
#: .\AMTS_items.json
msgid ""
"A UPS by A&M that stores more charge with less weight than standard UPS "
"modules."
msgstr "一款由A&M制造的UPS，相比标准UPS模块，能以更轻的重量存储更多电量。"

#: .\AMTS_items.json
msgid "Cute Portable Kitchen"
msgid_plural "Cute Portable Kitchens"
msgstr[0] "可爱便携厨房"

#. ~ Description for {'str': 'Cute Portable Kitchen'}
#: .\AMTS_items.json
msgid ""
"A&M manufactured portable cooking set. There are supposedly very few of "
"these made due to the extrordinary costs, a direct consequence of using "
"A&M's proprietary advanced alloy in its construction."
msgstr "A&M制造的便携烹饪套装。据说由于使用了A&M专有的先进合金，制造成本极高，因此产量极少。"

#: .\AMTS_items.json
msgid "<color_pink>[AMTS] </color>EVE Scout Rifle"
msgid_plural "<color_pink>[AMTS] </color>EVE Scout Rifles"
msgstr[0] "<color_pink>[AMTS] </color>EVE侦察步枪"

#: .\AMTS_items.json
msgid ""
"An advanced prototype rifle. Has both semi-automatic and two-round burst "
"firing modes."
msgstr "一款先进的原型步枪。拥有半自动和两连发点射两种开火模式。"

#: .\AMTS_items.json
msgid "semi auto"
msgstr "半自动"

#: .\AMTS_items.json
msgid "burst"
msgstr "连发"

#: .\AMTS_items.json
msgid "<color_pink>[AMTS]</color> EVE Scout Rifle 7.62x51mm Magazine"
msgid_plural "<color_pink>[AMTS]</color> EVE Scout Rifle 7.62x51mm Magazines"
