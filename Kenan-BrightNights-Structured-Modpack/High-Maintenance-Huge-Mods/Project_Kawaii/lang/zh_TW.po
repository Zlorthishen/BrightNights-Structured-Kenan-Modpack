#: .\AMTS_items.json
msgid "Cute High Capacity UPS"
msgid_plural "Cute High Capacity UPSs"
msgstr[0] "可愛高容量UPS"

#. ~ Description for {'str': 'Cute High Capacity UPS'}
#: .\AMTS_items.json
msgid ""
"A UPS by A&M that stores more charge with less weight than standard UPS "
"modules."
msgstr "一款由A&M製造的UPS，相比標準UPS模塊，能以更輕的重量存儲更多電量。"

#: .\AMTS_items.json
msgid "Cute Portable Kitchen"
msgid_plural "Cute Portable Kitchens"
msgstr[0] "可愛便攜廚房"

#. ~ Description for {'str': 'Cute Portable Kitchen'}
#: .\AMTS_items.json
msgid ""
"A&M manufactured portable cooking set. There are supposedly very few of "
"these made due to the extrordinary costs, a direct consequence of using "
"A&M's proprietary advanced alloy in its construction."
msgstr "A&M製造的便攜烹飪套裝。據說由於使用了A&M專有的先進合金，製造成本極高，因此產量極少。"

#: .\AMTS_items.json
msgid "<color_pink>[AMTS] </color>EVE Scout Rifle"
msgid_plural "<color_pink>[AMTS] </color>EVE Scout Rifles"
msgstr[0] "<color_pink>[AMTS] </color>EVE偵察步槍"

