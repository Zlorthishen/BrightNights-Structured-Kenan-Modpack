#. ~ Use action msg for {'str': 'Cute Rita and Rosa (attack mode)'}.
#: .\weapon.json
msgid "You equip Rosa and concentrate on defence"
msgstr "你裝備羅莎並專注於防禦"

#: .\weapon.json
msgid "Cute Twin Crystals (paired blades form)"
