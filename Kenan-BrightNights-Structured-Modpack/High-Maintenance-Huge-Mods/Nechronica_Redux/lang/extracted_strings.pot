msgstr ""

#: .\nec_mutations.json
msgid "Extra Head"
msgstr ""

#. ~ Description for {'str': 'Extra Head'}
#: .\nec_mutations.json
msgid ""
"There is another head on your shoulders. And here you thought you were doing"
