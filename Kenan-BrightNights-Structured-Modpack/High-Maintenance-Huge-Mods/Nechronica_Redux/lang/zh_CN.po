#: .\nec_professions.json
msgctxt "profession_male"
msgid "Baroque Doll"
msgstr "巴洛克人偶"

#: .\nec_professions.json
msgctxt "profession_female"
msgid "Baroque Doll"
msgstr "巴洛克人偶"

#. ~ Profession (male Baroque Doll) description
#: .\nec_professions.json
