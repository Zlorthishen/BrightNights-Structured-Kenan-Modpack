"<color_light_red>The ravager flesh heap swings its bladed tentacle!</color>"
msgstr "<color_light_red>掠奪者血肉堆揮舞它的刃狀觸手！</color>"

#: .\Modification Files\Monsters\-Essentials\secro_effects.json
