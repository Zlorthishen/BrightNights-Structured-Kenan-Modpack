msgstr "将物品放置于此。别担心，它们不会溶解。"

#: .\Modification Files\Maps\-Essentials\flesh_ter_furn_camp.json
msgid "flesh container"
msgstr "血肉容器"

#. ~ Description for flesh container
#: .\Modification Files\Maps\-Essentials\flesh_ter_furn_camp.json
msgid ""
"A large sack of flesh for storing liquids, with a vented suction point for "
"ease of use."
msgstr "一个用于储存液体的大型血肉袋，带有通风吸口以便使用。"

#: .\Modification Files\Maps\-Essentials\flesh_ter_furn_camp.json
msgid "bioluminescent wart"
msgstr "生物发光疣"

#. ~ Description for bioluminescent wart
#: .\Modification Files\Maps\-Essentials\flesh_ter_furn_camp.json
msgid "This bulbous clump of warts emit bioluminescent lights."
msgstr "这团球状疣簇会发出生物荧光。"

