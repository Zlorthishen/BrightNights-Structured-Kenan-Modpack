#: .\Modification Files\Others\secro_mutation.json
msgid "Potent Tendrils"
msgstr ""

#. ~ Description for {'str': 'Potent Tendrils'}
#: .\Modification Files\Others\secro_mutation.json
msgid "Your tendrils can infect the entire area further."
msgstr ""

#: .\Modification Files\Others\secro_mutation.json
msgid "Tendril Domination"
msgstr ""

#. ~ Description for {'str': 'Tendril Domination'}
#: .\Modification Files\Others\secro_mutation.json
msgid ""
"Your tendrils can infect the entire area even further and can convert "
"terrain much faster."
msgstr ""

#: .\Modification Files\Others\secro_mutation.json
msgid "Bio-organic Construction"
msgstr ""

#. ~ Description for {'str': 'Bio-organic Construction'}
#: .\Modification Files\Others\secro_mutation.json
msgid "You can build a variety of structures using flesh."
msgstr ""

#: .\Modification Files\Others\secro_mutation.json
msgid "Widespread Bio-organic Construction"
msgstr ""

#. ~ Description for {'str': 'Widespread Bio-organic Construction'}
#: .\Modification Files\Others\secro_mutation.json
