msgstr ""

#: .\Modification Files\Others\secro_mutation.json
msgid "Flesh Hivemind"
msgstr ""

#. ~ Description for {'str': 'Flesh Hivemind'}
#: .\Modification Files\Others\secro_mutation.json
msgid "You might be immobile, but you have the power to dominate the world!"
msgstr ""

#: .\Modification Files\Others\secro_mutation.json
msgid "Flesh Hivemind - Active"
msgstr ""

#. ~ Description for {'str': 'Flesh Hivemind - Active'}
#: .\Modification Files\Others\secro_mutation.json
