msgid "Sheath blade"
msgstr "鞘刃"

#: .\vo_kaihen.json
msgid "noise emitter (on)"
msgid_plural "noise emitter (on)s"
msgstr[0] "噪音發射器（開啟）"

#: .\vo_kaihen.json
