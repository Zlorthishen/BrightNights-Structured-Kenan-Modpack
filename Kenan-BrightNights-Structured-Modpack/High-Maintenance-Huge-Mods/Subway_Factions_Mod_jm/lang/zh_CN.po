msgid_plural "8.6mm Standard Rounds"
msgstr[0] "8.6毫米标准弹"

#: .\UnderRail\sgs_ammo.json
msgid "Standard acid charge"
msgstr "标准酸液装药"

#: .\UnderRail\sgs_ammo.json
msgid "Acid vial"
msgid_plural "Acid vials"
msgstr[0] "酸液瓶"

#. ~ Description for {'str': 'Acid vial'}
#: .\UnderRail\sgs_ammo.json
msgid ""
"A small glass vial containing a pre-measured charge of caustic acid. Be "
"careful!"
msgstr "一个小玻璃瓶，内含预先测量好的腐蚀性酸液。小心！"

#. ~ Description for {'str': '5mm Standard Round'}
#: .\UnderRail\sgs_ammo.json
msgid ""
"A 5mm cartridge commonly seen in usage with low-power firearms common in the"
" underrail."
msgstr "一种5毫米弹药，常见于地铁下层轨道普遍使用的低威力枪械。"

#: .\UnderRail\sgs_ammo.json
msgid "5mm Standard Round, reloaded"
msgid_plural "5mm Standard Round, reloadeds"
msgstr[0] "5毫米标准弹，复装"

#: .\UnderRail\sgs_ammo.json
msgid "5mm Standard Round, black powder"
msgid_plural "5mm Standard Round, black powders"
msgstr[0] "5毫米标准弹，黑火药"

#: .\UnderRail\sgs_ammo.json
msgid "5mm Standard Round JHP"
msgid_plural "5mm Standard Round JHPs"
msgstr[0] "5毫米标准弹JHP"

#. ~ Description for {'str': '5mm Standard Round JHP'}
