msgid ""
"A 5mm cartridge commonly seen in usage with low-power firearms common in the"
" underrail. This variant features jacketed hollow point bullet in-lieu of a "
"conventional bullet, increasing stopping power."
msgstr "一种5毫米弹药，常见于地铁下层轨道普遍使用的低威力枪械。此变种采用被甲空尖弹代替常规子弹，增加了停止力。"

#: .\UnderRail\sgs_ammo.json
msgid "5mm W2C Round"
msgid_plural "5mm W2C Rounds"
msgstr[0] "5毫米W2C弹"

#. ~ Description for {'str': '5mm W2C Round'}
#: .\UnderRail\sgs_ammo.json
msgid ""
"A 5mm cartridge commonly seen in usage with low-power firearms common in the"
" underrail. This variant features tungsten carbide bullet in-lieu of a "
"conventional bullet, increasing stopping power."
msgstr "一种5毫米弹药，常见于地铁下层轨道普遍使用的低威力枪械。此变种采用碳化钨弹代替常规子弹，增加了停止力。"

#: .\UnderRail\sgs_ammo.json
msgid "5mm standard round casing"
msgid_plural "5mm standard round casings"
msgstr[0] "5毫米标准弹弹壳"

#. ~ Description for {'str': '5mm standard round casing'}
#: .\UnderRail\sgs_ammo.json
