msgid_plural "gray wheels"
msgstr[0] "灰色车轮"

#: .\blaze_blob_parts.json
msgid "gray walkway"
msgstr "灰色走道"

#: .\blaze_blob_parts.json
msgid "gray wall"
msgstr "灰色墙壁"

#. ~ Description for {'str': 'gray wall'}
#. ~ Description for {'str': 'ooze barrier'}
#: .\blaze_blob_parts.json
msgid ""
"A living blob, formed into a vehicle wall.  Keeps zombies outside the "
"vehicle and prevents people from seeing through it."
msgstr "一个活体团块，塑造成车辆墙壁。能将僵尸挡在车外，并防止人们看穿它。"

#: .\blaze_blob_parts.json
msgid "gray hatch"
msgstr "灰色舱口"

#: .\blaze_blob_parts.json
msgid "opaque gray hatch"
msgstr "不透明灰色舱口"

#: .\blaze_blob_parts.json .\items\vehicle\blaze_blob.json
msgid "earthen roller"
msgid_plural "earthen rollers"
msgstr[0] "土质滚轮"

#: .\blaze_blob_parts.json
msgid "gel quarterpanel"
msgstr "凝胶侧板"

#. ~ Description for {'str': 'gel quarterpanel'}
#. ~ Description for {'str': 'gray barricade'}
#. ~ Description for {'str': 'ooze screen'}
#: .\blaze_blob_parts.json
msgid ""
"A living blob, formed into a half-height vehicle wall.  Keeps zombies "
"outside the vehicle but allows people to see over it."
msgstr "一个活体团块，塑造成半高车辆墙壁。能将僵尸挡在车外，但允许人们从上方看过去。"

#: .\blaze_blob_parts.json
msgid "gray barricade"
msgstr "灰色路障"

#: .\blaze_blob_parts.json
msgid "ooze screen"
msgstr "软泥屏幕"

#: .\blaze_blob_parts.json .\items\vehicle\blaze_blob.json
msgid "blobsaw"
msgid_plural "blobsaws"
msgstr[0] "团块锯"

#: .\blaze_blob_parts.json .\items\vehicle\blaze_blob.json
msgid "fuel puffer"
msgid_plural "fuel puffers"
msgstr[0] "燃料喷发器"

#: .\blaze_blob_parts.json .\items\vehicle\blaze_blob.json
msgid "acid puffer"
msgid_plural "acid puffers"
msgstr[0] "酸液喷发器"

#: .\blaze_blob_parts.json
msgid "ooze retriever"
msgstr "软泥回收器"

#: .\blaze_blob_parts.json
msgid "ooze harness"
msgstr "软泥背带"

#: .\blaze_blob_parts.json
msgid "pod (20L)"
msgstr "荚囊（20升）"

#: .\blaze_blob_parts.json
