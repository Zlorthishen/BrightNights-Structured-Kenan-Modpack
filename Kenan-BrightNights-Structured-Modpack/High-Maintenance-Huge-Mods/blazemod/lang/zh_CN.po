msgid_plural "gel puffers"
msgstr[0] "凝胶膨胀体"

#: .\blaze_blob_parts.json .\items\vehicle\blaze_blob.json
msgid "fire puffer"
msgid_plural "fire puffers"
msgstr[0] "火焰膨胀体"

#: .\blaze_blob_parts.json .\items\vehicle\blaze_blob.json
msgid "spark blight"
msgid_plural "spark blights"
msgstr[0] "火花枯萎体"

#: .\blaze_override.json
msgid "manual flamethrower"
msgstr "手动火焰喷射器"

#: .\blaze_override.json
msgid "BAR turret"
msgstr "BAR机枪炮塔"

#: .\blaze_override.json
msgid "M249 turret"
msgstr "M249机枪炮塔"

#: .\blaze_override.json
