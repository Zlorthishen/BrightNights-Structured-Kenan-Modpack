msgstr "自动霰弹枪炮塔"

#: .\blaze_override.json
msgid "M134D-H Minigun turret"
msgstr "M134D-H迷你机枪炮塔"

#: .\blaze_override.json
msgid "Mark 19 turret"
msgstr "Mark 19炮塔"

