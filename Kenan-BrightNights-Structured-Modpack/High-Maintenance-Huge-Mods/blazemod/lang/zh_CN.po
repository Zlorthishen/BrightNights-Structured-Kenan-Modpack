#: .\blaze_blob_parts.json
msgid "amorphous core"
msgstr "无定形核心"

#. ~ Description for {'str': 'amorphous core'}
#: .\blaze_blob_parts.json
msgid "An amorphous mass, the living heart and brain of a blob vehicle."
msgstr "一团不定形物质，是黏液载具的活体心脏与大脑。"

#: .\blaze_blob_parts.json
msgid "inert core"
msgstr "惰性核心"

#. ~ Description for {'str': 'inert core'}
#: .\blaze_blob_parts.json
msgid ""
"A sleeping amorphous core, acting as a rotating, universal mount for a "
"weapon.  If your hands are empty, you can stand next to a tentacle and "
"'f'ire the weapon by selecting the tile."
msgstr "一个沉睡的不定形核心，作为武器的旋转式通用支架。若你双手空空，可站在触手旁，通过选择对应格子按'f'键开火使用武器。"

#: .\blaze_blob_parts.json .\items\vehicle\blaze_blob.json
msgid "gel spouter"
msgid_plural "gel spouters"
msgstr[0] "凝胶喷射器"

#. ~ Description for {'str': 'gel spouter'}
#. ~ Description for {'str': 'gel spiker'}
#. ~ Description for {'str': 'gel lancer'}
#. ~ Description for {'str': 'gel razor'}
#. ~ Description for {'str': 'shock bulb'}
#. ~ Description for {'str': 'gel puffer'}
#. ~ Description for {'str': 'fire puffer'}
#. ~ Description for {'str': 'spark blight'}
#: .\blaze_blob_parts.json
msgid "A living blob turned into a heavy vehicle weapon."
msgstr "一个被改造成重型载具武器的活体黏液团。"

#: .\blaze_blob_parts.json .\items\vehicle\blaze_blob.json
msgid "gel spiker"
msgid_plural "gel spikers"
msgstr[0] "凝胶尖刺器"

#: .\blaze_blob_parts.json .\items\vehicle\blaze_blob.json
