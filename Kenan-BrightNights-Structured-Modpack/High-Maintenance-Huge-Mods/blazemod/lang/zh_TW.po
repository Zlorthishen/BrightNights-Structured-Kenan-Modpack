msgid_plural "growing cold mass"
msgstr[0] "生長中的寒冷團塊"

#: .\items\tools\blob_tools.json .\items\vehicle\blaze_blob.json
msgid "growing hairy mass"
msgid_plural "growing hairy mass"
msgstr[0] "生長中的多毛團塊"

