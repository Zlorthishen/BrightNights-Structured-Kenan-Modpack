msgstr "手動超高速驅動器"

#: .\items\guns\blaze_weapons_parts.json
msgid "manual ripper"
msgstr "手動撕裂者"

#: .\items\guns\blaze_weapons_parts.json
msgid "manual rotary speargun"
msgstr "手動旋轉魚叉槍"

#: .\items\guns\blaze_weapons_parts.json
msgid "manual scorpion ballista"
msgstr "手動蠍弩"

#: .\items\guns\blaze_weapons_parts.json
msgid "manual splintergun"
msgstr "手動碎片槍"

#: .\items\guns\blaze_weapons_parts.json
msgid "manual speargun"
msgstr "手動魚叉槍"

#: .\items\guns\blaze_weapons_parts.json
