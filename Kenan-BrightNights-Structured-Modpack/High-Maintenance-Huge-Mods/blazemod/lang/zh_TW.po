msgid "gelatinous capsule"
msgid_plural "gelatinous capsules"
msgstr[0] "凝膠膠囊"

#. ~ Description for {'str': 'gelatinous capsule'}
#. ~ Description for {'str': 'gray cocoon'}
#. ~ Description for {'str': 'oozing pod'}
