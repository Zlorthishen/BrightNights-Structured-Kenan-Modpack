msgid "soy"
msgstr "大豆"

#: .\a_materials.json
msgid "squished"
msgstr "壓扁的"

#: .\a_materials.json
msgid "cut"
msgstr "割破"

#: .\a_materials.json
msgid "lightly damaged"
msgstr "輕微受損"

#: .\a_materials.json
msgid "damaged"
msgstr "受損"

#: .\a_materials.json
