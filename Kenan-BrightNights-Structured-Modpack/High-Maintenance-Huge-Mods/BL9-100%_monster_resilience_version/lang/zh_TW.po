#. ~ Description for {'str': 'BL9 enhanced heat-resistant tank'}
#: .\Items\magazines.json
msgid ""
"A makeshift 2L canister containing a living liquified BL9 that is almost in "
"a magmatic state, may be used in a makeshift `BL9 melting sprayer`"
msgstr "一個臨時製作的2升罐子，內含活體液化BL9，幾乎處於岩漿狀態，可用於臨時製作的`BL9熔化噴霧器`"

#: .\Items\magazines.json
msgid "BL9 super acid-resistant tank"
msgid_plural "BL9 super acid-resistant tanks"
msgstr[0] "BL9超級耐酸罐"

#. ~ Description for {'str': 'BL9 super acid-resistant tank'}
#: .\Items\magazines.json
msgid ""
