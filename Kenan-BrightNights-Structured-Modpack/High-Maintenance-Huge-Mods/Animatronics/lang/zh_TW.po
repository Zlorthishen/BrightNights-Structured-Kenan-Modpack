#: .\speech.json
msgid "\"WHIIIRRRCRRIIIIZZZZZZVVVT\""
msgstr "\"嗚嗚嗚咔咔咔滋滋滋嘶嘶嘶嘶嘶嘶\""

#: .\speech.json
msgid "\"Let's rock!\""
msgstr "\"讓我們搖滾起來！\""

#: .\speech.json
msgid "\"Let's Party!\""
msgstr "\"派對開始！\""

#: .\speech.json
msgid "\"Are you ready?\""
msgstr "\"你準備好了嗎？\""
